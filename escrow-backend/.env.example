# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# --- Supabase (also used for image storage) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="escrow-images"

# --- Monnify (Sandbox first, swap to live base URL later) ---
MONNIFY_BASE_URL="https://sandbox.monnify.com"
MONNIFY_API_KEY=""
MONNIFY_SECRET_KEY="" # also used to validate the monnify-signature header on incoming webhooks
MONNIFY_CONTRACT_CODE=""
MONNIFY_WALLET_ACCOUNT_NUMBER="" # the Monnify wallet account funds disburse FROM — see Account Details in the Monnify dashboard

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
# Use webhook mode once deployed; polling mode is fine for local dev
TELEGRAM_USE_WEBHOOK="false"
TELEGRAM_WEBHOOK_URL=""

# --- AI (NVIDIA NIM primary, OpenRouter fallback — both OpenAI-SDK compatible) ---
AI_PROVIDER="nvidia" # "nvidia" | "openrouter"
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="meta/llama-3.1-70b-instruct"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="meta-llama/llama-3.1-70b-instruct:free"

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="escrow@yourdomain.com"

# --- Redis (session state for in-progress Telegram deal drafts) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"
ADMIN_EMAIL="" # the one account allowed to resolve disputes

# --- App ---
PORT=3000
NODE_ENV="development"
PUBLIC_FRONTEND_URL="http://localhost:5173" # React dashboard app — buyer /pay/:dealId links point here (Render URL in prod)
